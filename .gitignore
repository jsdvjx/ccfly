# dependencies
node_modules/
.pnpm-store/

# build output
dist/
dist-ssr/
*.tsbuildinfo

# Go binaries (anchored so they don't swallow the go/cmd/ccfly source dir)
/bin/
/go/bin/
/go/ccfly
*.exe
!packages/cli/bin/
!packages/cli/bin/ccfly.js

# Prebuilt per-platform binaries land in npm/ccfly-<os>-<arch>/bin/ at
# build/release time (CI cross-compile). Ignore the binaries themselves but
# keep the subpackage layout (package.json + bin/.gitkeep) tracked.
/npm/*/bin/ccfly
/npm/*/bin/ccfly.exe
!/npm/*/bin/.gitkeep

# logs
*.log
npm-debug.log*
pnpm-debug.log*

# env / local
*.local
.env
.env.*

# editor / os
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.sw?

# claude code 会话本地数据
.claude/

# ccfly 粘贴/上传的图片暂存(运行时产物,非源码)
.ccfly-uploads/
/go/psmux.zip

# Windows 安装器构建时从 webdist PNG 生成(build-windows-installer.sh)
/scripts/windows/ccfly.ico
